""" 
EXERCÍCIO 14

Problema:
Faça um programa que busca uma matriz dentro de uma outra matriz maior e retorna uma lista com todas as ocorrências.
"""

qnt_linha_A, qnt_coluna_A = map(int, input("Entre os valores da matriz A, separados por espaços: linha, coluna:").split())
matriz_A = []
print("Entre os valores, separados por espaços:")
for i in range(qnt_linha_A):
    linha = list(map(int, input().split()))
    matriz_A.append(linha)

qnt_linha_B, qnt_coluna_B = map(int, input("Entre os valores da matriz B, separados por espaços: linha, coluna:").split())
matriz_B = []
print("Entre os valores, separados por espaços:")
for i in range(qnt_linha_B):
    linha = list(map(int, input().split()))
    matriz_B.append(linha)

ocorrencias = []

limite_linhas = qnt_linha_A - qnt_linha_B + 1
limite_colunas = qnt_coluna_A - qnt_coluna_B + 1

for i in range(limite_linhas):
    for j in range(limite_colunas):
        encontrou = True
        for x in range(qnt_linha_B):
            for y in range(qnt_coluna_B):
                if matriz_A[i + x][j + y] != matriz_B[x][y]:
                    encontrou = False
                    break
            if not encontrou:
                break
        if encontrou:
            ocorrencias.append([i, j])
print(ocorrencias)

