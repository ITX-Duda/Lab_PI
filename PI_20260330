qnt_linha2, qnt_coluna2, menor_valor2, maior_valor2 = map(int, input("Entre os valores da matriz 2, separados por espaços: linha, coluna, menor e maior valor da matriz: ").split())
matriz_1 = gerar_matriz(qnt_linha1, qnt_coluna1, menor_valor1, maior_valor1)
matriz_2 = gerar_matriz(qnt_linha2, qnt_coluna2, menor_valor2, maior_valor2)

for l in matriz_1:
    print(l)

for l in matriz_2:
    print(l)

