### 🔄 Matriz transposta

```python
def transposta(M):
    if not eh_matriz(M):
        return []
    L, C = len(M), len(M[0])
    T = [[0]*L for _ in range(C)]
    for i in range(L):
        for j in range(C):
            T[j][i] = M[i][j]
    return T
```

### 🔄 Verificar se é simétrica

```python
def eh_simetrica(M):
    if not eh_matriz(M) or len(M) != len(M[0]):
        return False
    n = len(M)
    for i in range(n):
        for j in range(i+1, n):
            if M[i][j] != M[j][i]:
                return False
    return True
```

